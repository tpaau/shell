import QtQuick
import QtQuick.Shapes
import qs.theme
import qs.config

// Material icon rendered from a `Shape` using SVG strings.
//
// Using SVGs with shape paths has several advantages to using the material icons font:
//   1. Less RAM usage
//   2. No need to ship the icon font with the shell
//   3. Font icons sometimes have seams at larger sizes and generally look bad.
//
// To add a new icon:
//   - Go to https://fonts.google.com/icons?icon.size=24&icon.set=Material+Symbols&icon.style=Rounded
//   - Enable Fill and choose the icon you want
//   - Download the icon SVG
//   - Run `svgtoqml icon.svg out.qml`
//   - Grab the SVG path from the `path` property from `PathSvg` on the generated component
//   - Paste the path to a new property on this component
//   - Add the new icon to the switch statement in this component
//   - Create a new entry for the `Type` enum in this component.
//   - Restart the shell to make sure that enum reloads
Item {
	id: root

	property bool fill: true
	property bool asynchronous: true
	property int implicitSize: Config.icons.size.regular
	property int grade: fill ? 0 : 5
	property int icon: MaterialIcon.Brightness7
	property color color: Theme.palette.on_surface

	readonly property int gradeScaleFactor: 100
	readonly property int normalizedGrade: grade * gradeScaleFactor / implicitSize

	enum Type {
		Brightness2,
		Brightness6,
		BrightnessEmpty,
		Headphones,
		Home,
		MicOff,
		Mic
	}

    implicitWidth: implicitSize
    implicitHeight: implicitSize

    transform: [
		Translate {
			x: 0
			y: 960
		},
		Scale {
			xScale: root.width / 960
			yScale: root.height / 960
		}
    ]

    Shape {
		id: shape
		preferredRendererType: Shape.CurveRenderer

        ShapePath {
            strokeColor: root.color
			strokeWidth: root.normalizedGrade
			fillColor: root.fill ? root.color : "transparent"
            fillRule: ShapePath.WindingFill
			asynchronous: root.asynchronous

			PathSvg {
				path: switch (root.icon) {
					case MaterialIcon.Brightness2:
						return root.brightness2
					case MaterialIcon.Brightness6:
						return root.brightness6
					case MaterialIcon.BrightnessEmpty:
						return root.brightnessEmpty
					case MaterialIcon.Headphones:
						return root.headphones
					case MaterialIcon.Home:
						return root.home
					case MaterialIcon.MicOff:
						return root.mic_off
					case MaterialIcon.Mic:
						return root.mic
					default:
						console.warn(`No material icon for id ${root.icon}`)
						return root.home
				}
			}
        }
    }

