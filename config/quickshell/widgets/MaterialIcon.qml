					case MaterialIcon.Brightness6:
						return root.brightness6
					case MaterialIcon.Brightness7:
						return root.brightness7
					case MaterialIcon.BrightnessEmpty:
						return root.brightness_empty
					case MaterialIcon.BrokenImage:
						return root.broken_image
					case MaterialIcon.Error:
						return root.error
					case MaterialIcon.Favorite:
						return root.favorite
					case MaterialIcon.Fingerprint:
						return root.fingerprint
					case MaterialIcon.GraphicEq:
						return root.graphic_eq
					case MaterialIcon.HeartCheck:
						return root.heart_check
					case MaterialIcon.Headphones:
						return root.headphones
					case MaterialIcon.Home:
						return root.home
					case MaterialIcon.Info:
						return root.info
					case MaterialIcon.Lock:
						return root.lock
					case MaterialIcon.MicOff:
						return root.mic_off
					case MaterialIcon.Mic:
						return root.mic
					case MaterialIcon.NotificationsOff:
						return root.notifications_off
					case MaterialIcon.NotificationSettings:
						return root.notification_settings
					case MaterialIcon.Notifications:
						return root.notifications
					case MaterialIcon.PowerSettingsNew:
						return root.power_settings_new
					case MaterialIcon.ScreenshotMonitor:
						return root.screenshot_monitor
